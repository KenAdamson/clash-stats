{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Battles Scraped",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(battles_scraped_total[10m])",
          "legendFormat": "{{corpus}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars", "barAlignment": 0 }
        }
      }
    },
    {
      "title": "Total Battles",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(battles_scraped_total)",
          "legendFormat": "Scraped",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "title": "Replays Fetched vs Failed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(replays_fetched_total[10m])",
          "legendFormat": "fetched ({{source}})",
          "refId": "A"
        },
        {
          "expr": "increase(replays_failed_total[10m])",
          "legendFormat": "failed ({{error_type}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars", "barAlignment": 0 }
        }
      }
    },
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(api_requests_total[5m])",
          "legendFormat": "{{endpoint}} ({{status}})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "API Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(api_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(api_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Pipeline Health",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(corpus_players_active)",
          "legendFormat": "Active Players",
          "refId": "A"
        },
        {
          "expr": "sum(increase(replays_fetched_total[1h]))",
          "legendFormat": "Replays (1h)",
          "refId": "B"
        },
        {
          "expr": "sum(increase(battles_scraped_total[1h]))",
          "legendFormat": "Battles (1h)",
          "refId": "C"
        },
        {
          "expr": "sum(increase(replays_failed_total[1h])) / (sum(increase(replays_fetched_total[1h])) + sum(increase(replays_failed_total[1h])))",
          "legendFormat": "Error Rate (1h)",
          "refId": "D"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Active Players" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Battles (1h)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Replays (1h)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Error Rate (1h)" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 1 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.1 },
                { "color": "red", "value": 0.3 }
              ]}}
            ]
          }
        ]
      }
    },
    {
      "title": "Scrape Runs (24h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(scrape_runs_total{outcome=\"success\"}[24h]))",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(increase(scrape_runs_total{outcome=\"partial\"}[24h]))",
          "legendFormat": "Partial",
          "refId": "B"
        },
        {
          "expr": "sum(increase(scrape_runs_total{outcome=\"failed\"}[24h]))",
          "legendFormat": "Failed",
          "refId": "C"
        }
      ],
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Success" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Partial" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      }
    },
    {
      "title": "Container Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"cr-tracker|cr-browser\"} |= ``",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["clash-royale", "pipeline"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Clash Royale Pipeline",
  "uid": "cr-pipeline"
}
